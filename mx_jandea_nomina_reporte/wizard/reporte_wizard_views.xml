<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_reporte_wizard_form" model="ir.ui.view">
        <field name="name">mx.jandea.nomina.reporte.wizard.form</field>
        <field name="model">mx.jandea.nomina.reporte.wizard</field>
        <field name="arch" type="xml">
            <form string="Listado de Nómina (Excel)">
                <group>
                    <field name="modo" widget="radio"/>
                    <field name="payslip_run_id"
                           invisible="modo != 'lote'" required="modo == 'lote'"/>
                    <field name="company_id" options="{'no_create': True}"/>
                    <field name="date_from"
                           invisible="modo != 'mensual'" required="modo == 'mensual'"/>
                    <field name="date_to"
                           invisible="modo != 'mensual'" required="modo == 'mensual'"/>
                </group>
                <footer>
                    <button name="action_generar" string="Generar Excel"
                            type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_reporte_wizard" model="ir.actions.act_window">
        <field name="name">Listado de Nómina (Excel)</field>
        <field name="res_model">mx.jandea.nomina.reporte.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
