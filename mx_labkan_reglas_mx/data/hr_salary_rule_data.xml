    <!-- =================== DEDUCCIONES (entran a NET vía categoría DED) =================== -->
    <!-- sequence entre Child Support (174) y NET (200), mismo patrón que
         Deduction nativo (198) -->

    <record id="rule_anticipo_nomina" model="hr.salary.rule">
        <field name="name">Anticipo de Nómina</field>
        <field name="code">ANTICIPO_NOMINA</field>
        <field name="category_id" ref="hr_payroll.DED"/>
        <field name="sequence">180</field>
        <field name="condition_select">input</field>
        <field name="condition_other_input_id" ref="input_anticipo_nomina"/>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = -inputs['ANTICIPO_NOMINA'].amount</field>
        <field name="struct_id" ref="l10n_mx_hr_payroll.l10n_mx_regular_pay"/>
    </record>

    <record id="rule_caja_ahorro" model="hr.salary.rule">
