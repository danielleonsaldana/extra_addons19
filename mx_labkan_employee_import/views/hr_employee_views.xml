<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Herencia del formulario de empleado -->
    <record id="view_hr_employee_form_teva" model="ir.ui.view">
        <field name="name">hr.employee.form.teva</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <!-- ─── TEVA ──────────────────────────────────────────────── -->
                <page string="Datos TEVA" name="teva_data">
                    <group col="4">
                        <group string="Identificación TEVA">
                            <field name="teva_cliente"/>
                            <field name="teva_sucursal"/>
                            <field name="teva_estatus"/>
                            <field name="teva_esquema"/>
                            <field name="teva_rp"/>
                            <field name="teva_contrato"/>
                        </group>
                        <group string="Puesto TEVA">
                            <field name="teva_puesto"/>
                            <field name="teva_descripcion_puesto"/>
                            <field name="fecha_antiguedad"/>
                            <field name="fecha_baja"/>
                        </group>
                        <group string="IMSS / Seguridad Social">
                            <field name="nss"/>
                            <field name="infonavit_credit"/>
                            <field name="infonavit_factor"/>
                            <field name="infonavit_pct"/>
                            <field name="infonavit_pesos"/>
                            <field name="fonacot_retention"/>
                        </group>
                        <group string="Datos Bancarios">
                            <field name="bank_name"/>
                            <field name="bank_account_number"/>
                            <field name="bank_card_number"/>
                            <field name="bank_clabe"/>
                        </group>
                    </group>
                </page>

                <!-- ─── Salario Informativo ───────────────────────────────── -->
                <page string="Salario (Informativo)" name="salary_info">
                    <group>
                        <group string="Desglose salarial">
                            <field name="salary_monthly"/>
                            <field name="salary_biweekly"/>
                            <field name="salary_daily"/>
                        </group>
                        <group string="Composición IMSS / Exento">
                            <field name="salary_imss"/>
                            <field name="salary_exempt"/>
                            <field name="salary_total_info" readonly="1"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert" style="margin-top:8px;">
                        <i class="fa fa-info-circle"/> Este tab es <b>solo informativo</b>.
                        El salario real para cálculo de nómina se configura desde el contrato del empleado.
                    </div>
                </page>

                <!-- ─── RFC / SAT ─────────────────────────────────────────── -->
                <page string="RFC / SAT" name="rfc_sat">
                    <group>
                        <group string="Datos Fiscales">
                            <field name="mx_rfc" string="RFC"/>
                            <field name="mx_curp" string="CURP"/>
                            <field name="nss" string="NSS (IMSS)"/>
                        </group>
                        <group string="Validación">
                            <field name="rfc_validated_format" readonly="1"/>
                            <field name="rfc_sat_status" readonly="1"/>
                            <field name="rfc_sat_checked_date" readonly="1"/>
                        </group>
                    </group>
                    <div style="margin-top: 12px; display:flex; gap:8px;">
                        <button name="action_validate_rfc_format"
                                string="✓ Validar Formato RFC"
                                type="object"
                                class="btn btn-secondary"/>
                        <button name="action_verify_rfc_sat"
                                string="🌐 Verificar en SAT"
                                type="object"
                                class="btn btn-primary"
                                confirm="Se realizará una consulta al SAT. ¿Continuar?"/>
                    </div>
                </page>

                <!-- ─── Multi-Empresa ─────────────────────────────────────── -->
                <page string="Multi-Empresa" name="multicompany">
                    <group>
                        <field name="is_multicompany_employee" readonly="1"
                               string="¿Empleado en múltiples empresas?"/>
                    </group>
                    <field name="related_employee_ids"
                           widget="many2many_tags"
                           string="Este mismo empleado en otras empresas:"/>
                </page>

            </xpath>
        </field>
    </record>

    <!-- List view -->
    <record id="view_hr_employee_list_teva" model="ir.ui.view">
        <field name="name">hr.employee.list.teva</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="mx_rfc" string="RFC" optional="show"/>
                <field name="nss" string="NSS" optional="hide"/>
                <field name="rfc_validated_format" optional="show" string="RFC ✓"/>
                <field name="rfc_sat_status" optional="show" string="SAT"/>
                <field name="salary_total_info" optional="show" string="Salario Total (info)"/>
                <field name="is_multicompany_employee" optional="show" string="Multi-Emp"/>
            </xpath>
        </field>
    </record>

</odoo>
