<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_reporte_map_list" model="ir.ui.view">
        <field name="name">mx.jandea.nomina.reporte.map.list</field>
        <field name="model">mx.jandea.nomina.reporte.map</field>
        <field name="arch" type="xml">
            <list string="Mapeo de columnas" editable="bottom">
                <field name="columna"/>
                <field name="codes"/>
                <field name="company_id"/>
                <field name="notas"/>
            </list>
        </field>
    </record>

    <record id="action_reporte_map" model="ir.actions.act_window">
        <field name="name">Mapeo de Columnas (Excel)</field>
        <field name="res_model">mx.jandea.nomina.reporte.map</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Configura el mapeo columna → códigos</p>
            <p>Cada columna de dinero del Listado de Nómina se llena sumando las
               líneas del recibo cuyos códigos de regla coincidan con los que
               indiques aquí (separados por coma).</p>
        </field>
    </record>

</odoo>
