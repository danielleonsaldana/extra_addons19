<?xml version="1.0"?>
<odoo>
    <record id="view_hr_document_template_list" model="ir.ui.view">
        <field name="name">hr.document.template.list</field>
        <field name="model">hr.document.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="doc_type"/>
                <field name="name"/>
                <field name="empresa_referencia"/>
                <field name="gender"/>
            </list>
        </field>
    </record>

    <record id="view_hr_document_template_form" model="ir.ui.view">
        <field name="name">hr.document.template.form</field>
        <field name="model">hr.document.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="doc_type"/>
                            <field name="gender"/>
                            <field name="empresa_referencia"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="file" filename="filename"/>
                            <field name="filename" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Placeholders {{ }} disponibles en este .docx..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_document_template" model="ir.actions.act_window">
        <field name="name">Plantillas de Documentos</field>
        <field name="res_model">hr.document.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_document_template"
              name="Plantillas de Documentos"
              parent="hr_work_entry_enterprise.menu_hr_payroll_configuration"
              action="action_hr_document_template"
              sequence="100"/>
</odoo>
