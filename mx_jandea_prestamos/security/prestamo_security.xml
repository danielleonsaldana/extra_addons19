<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Reglas multiempresa. Sin esto, el modelo mostraba préstamos de todas
        las compañías, y al leer el hr.salary.attachment vinculado (que SI
        tiene su regla nativa) reventaba con "Error de acceso".

        Se usa company_ids (compañías ACTIVADAS en el selector), igual que la
        regla nativa de hr.salary.attachment, para que ambos modelos filtren
        con el mismo criterio.
    -->

    <record id="rule_mx_jandea_prestamo_company" model="ir.rule">
        <field name="name">Préstamo a empleado: multiempresa</field>
        <field name="model_id" ref="model_mx_jandea_prestamo"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_mx_jandea_prestamo_linea_company" model="ir.rule">
        <field name="name">Línea de préstamo: multiempresa</field>
        <field name="model_id" ref="model_mx_jandea_prestamo_linea"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

</odoo>
