<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         Wizard: Importación Masiva de Empleados TEVA
    ══════════════════════════════════════════════════════════════════════════ -->
    <record id="view_employee_import_wizard_form" model="ir.ui.view">
        <field name="name">mx.employee.import.wizard.form</field>
        <field name="model">mx.employee.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importación Masiva de Empleados - Formato TEVA">
                <sheet>

                    <!-- Resumen de resultados (post-importación) -->
                    <div attrs="{'invisible': [('import_done','=',False)]}">
                        <div class="alert alert-success" role="alert">
                            <div class="row">
                                <div class="col-3 text-center">
                                    <h4 class="text-success">
                                        <field name="count_created" readonly="1"/>
                                    </h4>
                                    <small>Creados</small>
                                </div>
                                <div class="col-3 text-center">
                                    <h4 class="text-info">
                                        <field name="count_updated" readonly="1"/>
                                    </h4>
                                    <small>Actualizados</small>
                                </div>
                                <div class="col-3 text-center">
                                    <h4 class="text-warning">
                                        <field name="count_skipped" readonly="1"/>
                                    </h4>
                                    <small>Omitidos</small>
                                </div>
                                <div class="col-3 text-center">
                                    <h4 class="text-danger">
                                        <field name="count_error" readonly="1"/>
                                    </h4>
                                    <small>Errores</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <notebook>

                        <!-- ── Pestaña 1: Configuración ─────────────────── -->
                        <page string="📤 Configuración de Importación" name="config"
                              attrs="{'invisible': [('import_done','=',True)]}">

                            <group>
                                <group string="Archivo">
                                    <field name="file_data"
                                           widget="binary"
                                           filename="file_name"
                                           string="Archivo XLS/XLSX (formato TEVA)"
                                           required="1"/>
                                    <field name="file_name" invisible="1"/>
                                </group>
                                <group string="Destino">
                                    <field name="company_id" required="1"/>
                                    <field name="header_row"/>
                                </group>
                            </group>

                            <group>
                                <group string="Comportamiento ante duplicados">
                                    <field name="skip_duplicates"/>
                                    <field name="update_existing"
                                           attrs="{'invisible': [('skip_duplicates','=',False)]}"/>
                                </group>
                                <group string="Opciones adicionales">
                                    <field name="validate_rfc_format"/>
                                    <field name="link_multicompany"/>
                                </group>
                            </group>

                            <group string="Configuración de Salario Informativo">
                                <field name="salary_imss_pct"
                                       widget="percentage"
                                       help="Porcentaje del sueldo mensual que se considera 'parte IMSS'. El resto se guarda como exento. Dato solo informativo."/>
                                <div class="text-muted" style="font-size:0.85em; grid-column: span 2;">
                                    Ejemplo: si el sueldo mensual es $10,000 y el % IMSS es 70%, 
                                    entonces Parte IMSS = $7,000 y Parte Exenta = $3,000. 
                                    El campo <b>Salario Total (info)</b> mostrará $10,000.
                                </div>
                            </group>

                            <div class="alert alert-info mt-2" role="alert">
                                <i class="fa fa-file-excel-o"/> <b>Formato esperado:</b>
                                El archivo debe seguir la estructura TEVA de 52 columnas (plantilla de alta IMSS).
                                La fila 1 contiene encabezados; los datos inician en la fila 2.
                                Columnas clave: RFC (col 29), CURP (col 32), NSS (col 26), 
                                Sueldo Mensual (col 39), Apellido Paterno (col 8), Nombre (col 10).
                            </div>

                        </page>

                        <!-- ── Pestaña 2: Resultados ─────────────────────── -->
                        <page string="📋 Resultados" name="results"
                              attrs="{'invisible': [('import_done','=',False)]}">

                            <field name="result_line_ids" readonly="1">
                                <list decoration-success="status == 'created'"
                                      decoration-info="status == 'updated'"
                                      decoration-warning="status == 'skipped'"
                                      decoration-danger="status == 'error'">
                                    <field name="row_number" string="Fila" width="60px"/>
                                    <field name="employee_name" string="Nombre"/>
                                    <field name="rfc" string="RFC" width="140px"/>
                                    <field name="rfc_format_ok"
                                           widget="boolean"
                                           string="RFC ✓"
                                           width="80px"/>
                                    <field name="status"
                                           widget="badge"
                                           decoration-success="status == 'created'"
                                           decoration-info="status == 'updated'"
                                           decoration-warning="status == 'skipped'"
                                           decoration-danger="status == 'error'"
                                           string="Resultado"
                                           width="120px"/>
                                    <field name="message" string="Mensaje"/>
                                    <field name="employee_id"
                                           string="Empleado"
                                           optional="show"
                                           attrs="{'invisible': [('status','in',['error','skipped'])]}"/>
                                </list>
                            </field>

                        </page>

                    </notebook>

                </sheet>

                <footer>
                    <!-- Botones pre-importación -->
                    <button name="action_import"
                            string="🚀 Importar Empleados"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('import_done','=',True)]}"
                            confirm="¿Confirma la importación? Se crearán/actualizarán empleados en la empresa seleccionada."/>

                    <!-- Botones post-importación -->
                    <button name="action_open_employees"
                            string="Ver Empleados Importados"
                            type="object"
                            class="btn-secondary"
                            attrs="{'invisible': [('import_done','=',False)]}"/>

                    <button name="action_close"
                            string="Cerrar"
                            type="object"
                            class="btn-secondary"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- Action para abrir el wizard -->
    <record id="action_employee_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar Empleados (TEVA)</field>
        <field name="res_model">mx.employee.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_employee_import_wizard_form"/>
    </record>

</odoo>
