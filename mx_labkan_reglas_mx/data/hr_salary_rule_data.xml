        <field name="condition_other_input_id" ref="input_dias_festivo_laborado"/>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">
salario_diario = version.wage / 30
dias = inputs['DIAS_FESTIVO'].amount
result = salario_diario * 3 * dias
        </field>
        <field name="struct_id" ref="l10n_mx_hr_payroll.l10n_mx_regular_pay"/>
    </record>

    <record id="rule_prima_dominical" model="hr.salary.rule">
        <field name="name">Prima Dominical</field>
        <field name="code">PRIMA_DOM</field>
        <field name="category_id" ref="l10n_mx_hr_payroll.l10n_mx_category_taxable_alw"/>
        <field name="sequence">97</field>
        <field name="condition_select">input</field>
        <field name="condition_other_input_id" ref="input_domingos_trabajados"/>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">
salario_diario = version.wage / 30
domingos = inputs['DOMINGOS_PRIMA_DOM'].amount
result = salario_diario * domingos * 0.25
        </field>
        <field name="struct_id" ref="l10n_mx_hr_payroll.l10n_mx_regular_pay"/>
    </record>

