<?xml version="1.0"?>
<odoo>
    <!-- =======================================================================
         FIX: Regla ISR nativa — crash cuando GROSS = 0 (empleado con todas faltas)
         Se sobreescribe solo la fórmula Python; todo lo demás permanece igual.
         ======================================================================= -->
    <record id="l10n_mx_hr_payroll.l10n_mx_regular_pay_isr" model="hr.salary.rule">
        <field name="amount_python_compute">
def find_rates(x, rates):
    for low, high, fix, rate in rates:
        if low &lt;= x &lt;= high:
            return low, high, fix, rate
    # Guard: si GROSS no cae en ningún rango (ej. GROSS=0) usa el primer tramo
    return rates[0]

gross = categories['GROSS']
result = 0
if gross and gross &gt; 0:
    isr_table = payslip._rule_parameter('l10n_mx_isr_tables')[version.schedule_pay]
    low, high, fix, rate = find_rates(gross, isr_table)
    result = -((gross - low) * rate + fix)

period_factor = payslip._rule_parameter('l10n_mx_schedule_table')[version.schedule_pay]
if period_factor &gt;= 15:
    period_factor = (period_factor / 30) * (365 / 12)
min_wage = payslip._rule_parameter('l10n_mx_daily_min_wage') * period_factor

if gross &lt;= min_wage:
    result_qty = 0.0
        </field>
    </record>

    <!-- =======================================================================
         PERCEPCIONES COMPLEMENTARIAS
         Categoría: taxable_alw (mismo patrón que Commissions/Bonus nativos)
         → se suman automáticamente a GROSS e ISR nativos
         Sequence: 94-99 (entre Bonus nativo ~93 y GROSS ~100)

         SALARIO DIARIO DINÁMICO:
         wage en Odoo 19 siempre es mensual. Se divide entre los días reales
         del período del recibo (date_to - date_from + 1):
           Semanal  (7d)  → wage / 7
           Quincenal(15d) → wage / 15
           Mensual  (31d) → wage / 31
         Esto cumple LFT Art.82 sin hardcodear la periodicidad.
         ======================================================================= -->

    <record id="rule_horas_extra_dobles" model="hr.salary.rule">
        <field name="name">Horas Extra Dobles</field>
        <field name="code">HRS_EXTRA_DOBLE</field>
        <field name="category_id" ref="l10n_mx_hr_payroll.l10n_mx_category_taxable_alw"/>
        <field name="sequence">94</field>
        <field name="condition_select">input</field>
        <field name="condition_other_input_id" ref="input_horas_extra_dobles"/>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">
dias_periodo = (payslip.date_to - payslip.date_from).days + 1
salario_diario = version.wage / dias_periodo
horas_diarias = version.resource_calendar_id.hours_per_day or 8
horas = inputs['HRS_EXTRA_DOBLE'].amount
result = (salario_diario / horas_diarias) * 2 * horas
        </field>
        <field name="struct_id" ref="l10n_mx_hr_payroll.l10n_mx_regular_pay"/>
    </record>

    <record id="rule_horas_extra_triples" model="hr.salary.rule">
        <field name="name">Horas Extra Triples</field>
        <field name="code">HRS_EXTRA_TRIPLE</field>
        <field name="category_id" ref="l10n_mx_hr_payroll.l10n_mx_category_taxable_alw"/>
        <field name="sequence">95</field>
        <field name="condition_select">input</field>
        <field name="condition_other_input_id" ref="input_horas_extra_triples"/>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">
dias_periodo = (payslip.date_to - payslip.date_from).days + 1
salario_diario = version.wage / dias_periodo
horas_diarias = version.resource_calendar_id.hours_per_day or 8
horas = inputs['HRS_EXTRA_TRIPLE'].amount
result = (salario_diario / horas_diarias) * 3 * horas
        </field>
        <field name="struct_id" ref="l10n_mx_hr_payroll.l10n_mx_regular_pay"/>
    </record>

