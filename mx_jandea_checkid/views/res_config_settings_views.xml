<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_checkid" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.checkid</field>
        <field name="model">res.config.settings</field>
        <field name="priority">100</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="CheckId" name="mx_jandea_checkid"
                     groups="base.group_system">
                    <block title="Conexión API" name="checkid_api_block">
                        <setting string="API Key"
                                 help="Obtenla en https://www.checkid.mx/App/ControlApi">
                            <field name="checkid_api_key"
                                   password="True"
                                   placeholder="Ej: abc123xyz..."/>
                        </setting>
                        <setting string="Consulta automática"
                                 help="Consultar CheckId al crear o modificar el RFC/CURP del empleado.">
                            <field name="checkid_auto_query"/>
                        </setting>
                    </block>
                    <block title="Datos a obtener" name="checkid_data_block">
                        <setting string="RFC y Razón Social"
                                 help="RFC, Razón Social y vigencia ante el SAT.">
                            <field name="checkid_obtain_rfc"/>
                        </setting>
                        <setting string="CURP y datos personales"
                                 help="CURP, nombre, fecha de nacimiento y entidad.">
                            <field name="checkid_obtain_curp"/>
                        </setting>
                        <setting string="NSS"
                                 help="Número de Seguridad Social (IMSS).">
                            <field name="checkid_obtain_nss"/>
                        </setting>
                        <setting string="Régimen Fiscal"
                                 help="Régimen fiscal registrado ante el SAT.">
                            <field name="checkid_obtain_regimen"/>
                        </setting>
                        <setting string="CP Fiscal"
                                 help="Código Postal fiscal registrado en el SAT.">
                            <field name="checkid_obtain_cp"/>
                        </setting>
                        <setting string="Estado 69/69B (EFOS/EDOS)"
                                 help="Verificar si aparece en el listado 69 o 69B del SAT.">
                            <field name="checkid_obtain_69"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- Menú bajo Configuración de RR.HH. existente -->
    <menuitem
        id="menu_checkid_config"
        name="CheckId"
        parent="hr.menu_human_resources_configuration"
        action="action_checkid_config"
        sequence="99"
        groups="base.group_system"
    />

    <!-- Acción para abrir Settings en la sección CheckId -->
    <record id="action_checkid_config" model="ir.actions.act_window">
        <field name="name">Configuración CheckId</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'mx_jandea_checkid'}</field>
    </record>

    <!-- Menú raíz CheckId bajo HR (para Historial y Log) -->
    <menuitem
        id="menu_checkid_root"
        name="CheckId"
        parent="hr.menu_hr_root"
        sequence="98"
        groups="hr.group_hr_manager"
    />
</odoo>
