<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── hr.leave: agregar campos MX al formulario nativo ─────────────── -->
    <record id="view_hr_leave_form_mx" model="ir.ui.view">
        <field name="name">hr.leave.form.mx.jandea</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <!-- Insertar después del campo name (descripción) dentro de col_left -->
            <xpath expr="//group[@name='col_left']" position="inside">
                <field name="mx_motivo"
                       placeholder="Motivo de la ausencia..."
                       readonly="state != 'confirm'"/>
                <field name="mx_horas_parciales"
                       string="Horas de ausencia"
                       invisible="not holiday_status_id.mx_requires_hours"/>
                <field name="mx_origen" readonly="1" string="Origen"/>
            </xpath>
        </field>
    </record>

    <!-- ── hr.leave.type: agregar campos MX al formulario nativo ─────────── -->
    <!-- ID correcto en Odoo 19: edit_holiday_status_form -->
    <record id="view_hr_leave_type_form_mx" model="ir.ui.view">
        <field name="name">hr.leave.type.form.mx.jandea</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
        <field name="arch" type="xml">
            <!-- Agregar grupo MX antes del grupo de colores/display -->
            <xpath expr="//group[@name='visual']" position="before">
                <group string="Configuración MX" name="mx_config" col="2">
                    <field name="mx_code" string="Código de importación"
                           placeholder="Ej: FALT_INJ"/>
                    <field name="mx_deduction_type" string="Descuento en nómina"/>
                    <field name="mx_requires_hours" string="Requiere horas"/>
                    <field name="mx_sync_attendance" string="Sincronizar asistencias"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ── hr.leave: columnas adicionales en lista ───────────────────────── -->
    <record id="view_hr_leave_list_mx" model="ir.ui.view">
        <field name="name">hr.leave.list.mx.jandea</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="mx_motivo" optional="show" string="Motivo"/>
                <field name="mx_horas_parciales" optional="hide" string="Horas"/>
                <field name="mx_origen" optional="show" string="Origen"/>
            </xpath>
        </field>
    </record>

    <!-- ── Acción: Reporte de Faltas ─────────────────────────────────────── -->
    <record id="action_mx_jandea_faltas_report" model="ir.actions.act_window">
        <field name="name">Reporte de Faltas</field>
        <field name="res_model">hr.leave</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="domain">[('holiday_status_id.mx_code', '!=', False)]</field>
    </record>

</odoo>
