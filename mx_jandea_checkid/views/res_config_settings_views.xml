<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista form independiente para configuración CheckId -->
    <record id="view_checkid_config_form" model="ir.ui.view">
        <field name="name">mx.jandea.checkid.config.form</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Configuración CheckId" class="o_res_config_settings">
                <sheet>
                    <div class="o_setting_container">

                        <div class="settings_tab"/>

                        <div class="o_setting_box_column">

                            <h2>Integración CheckId (Canicalabs)</h2>

                            <!-- API Key -->
                            <div class="o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="checkid_api_key" class="o_form_label"/>
                                    <span class="text-muted d-block">
                                        Obtenla en https://www.checkid.mx/App/ControlApi
                                    </span>
                                    <div class="mt8">
                                        <field name="checkid_api_key"
                                               password="True"
                                               placeholder="Ej: abc123xyz..."
                                               style="width:400px"/>
                                    </div>
                                </div>
                            </div>

                            <!-- Consulta automática -->
                            <div class="o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="checkid_auto_query"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="checkid_auto_query" class="o_form_label"/>
                                    <span class="text-muted d-block">
                                        Consultar automáticamente al crear o modificar RFC/CURP del empleado.
                                    </span>
                                </div>
                            </div>

                            <h3 class="mt16">Datos a obtener</h3>

                            <div class="o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="checkid_obtain_rfc"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="checkid_obtain_rfc" class="o_form_label"/>
                                    <span class="text-muted d-block">RFC, Razón Social y vigencia ante el SAT.</span>
                                </div>
                            </div>

                            <div class="o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="checkid_obtain_curp"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="checkid_obtain_curp" class="o_form_label"/>
                                    <span class="text-muted d-block">CURP, nombre, fecha de nacimiento y entidad.</span>
                                </div>
                            </div>

                            <div class="o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="checkid_obtain_nss"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="checkid_obtain_nss" class="o_form_label"/>
                                    <span class="text-muted d-block">Número de Seguridad Social (IMSS).</span>
                                </div>
                            </div>

                            <div class="o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="checkid_obtain_regimen"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="checkid_obtain_regimen" class="o_form_label"/>
                                    <span class="text-muted d-block">Régimen fiscal registrado ante el SAT.</span>
                                </div>
                            </div>

                            <div class="o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="checkid_obtain_cp"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="checkid_obtain_cp" class="o_form_label"/>
                                    <span class="text-muted d-block">Código Postal fiscal registrado en el SAT.</span>
                                </div>
                            </div>

                            <div class="o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="checkid_obtain_69"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="checkid_obtain_69" class="o_form_label"/>
                                    <span class="text-muted d-block">Verificar si aparece en el listado 69 o 69B del SAT (EFOS/EDOS).</span>
                                </div>
                            </div>

                        </div>
                    </div>
                </sheet>
                <footer>
                    <button string="Guardar" type="object" name="execute"
                            class="btn-primary"/>
                    <button string="Descartar" type="object" name="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para abrir la configuración -->
    <record id="action_checkid_config" model="ir.actions.act_window">
        <field name="name">Configuración CheckId</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_checkid_config_form"/>
        <field name="target">inline</field>
        <field name="context">{'module' : 'mx_jandea_checkid'}</field>
    </record>

    <!-- Menú bajo el menú CheckId existente -->
    <menuitem
        id="menu_checkid_config"
        name="Configuración"
        parent="menu_checkid_root"
        action="action_checkid_config"
        sequence="20"
        groups="base.group_system"
    />
</odoo>
