<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_import_wizard_form" model="ir.ui.view">
        <field name="name">mx.employee.import.wizard.form</field>
        <field name="model">mx.employee.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importación Masiva de Empleados - Formato TEVA">
                <sheet>

                    <!-- ── Resumen post-importación ──────────────────────── -->
                    <div invisible="not import_done">
                        <div class="alert alert-success" role="alert">
                            <div class="row text-center">
                                <div class="col-3">
                                    <h4 class="text-success"><field name="count_created" readonly="1"/></h4>
                                    <small>Creados</small>
                                </div>
                                <div class="col-3">
                                    <h4 class="text-info"><field name="count_updated" readonly="1"/></h4>
                                    <small>Actualizados</small>
                                </div>
                                <div class="col-3">
                                    <h4 class="text-warning"><field name="count_skipped" readonly="1"/></h4>
                                    <small>Omitidos</small>
                                </div>
                                <div class="col-3">
                                    <h4 class="text-danger"><field name="count_error" readonly="1"/></h4>
                                    <small>Errores</small>
                                </div>
                            </div>
                        </div>

                        <!-- ── Bloque CheckId: pregunta ───────────────────── -->
                        <div invisible="not checkid_pending"
                             class="alert alert-warning mt-2" role="alert"
                             style="border-left: 5px solid #f0ad4e;">
                            <div class="row align-items-center">
                                <div class="col-8">
                                    <h5 style="margin:0;">
                                        <i class="fa fa-search"/> ¿Deseas validar los empleados con <b>CheckId</b>?
                                    </h5>
                                    <small class="text-muted">
                                        Se consultará RFC, CURP, NSS, Régimen Fiscal y lista 69/69B del SAT
                                        para cada empleado creado o actualizado. Esto consume créditos de tu cuenta CheckId.
                                    </small>
                                </div>
                                <div class="col-4 text-right" style="display:flex; gap:8px; justify-content:flex-end;">
                                    <button name="action_checkid_validate"
                                            string="✓ Sí, validar con CheckId"
                                            type="object"
                                            class="btn btn-warning btn-sm"/>
                                    <button name="action_skip_checkid"
                                            string="✗ Ahora no"
                                            type="object"
                                            class="btn btn-secondary btn-sm"/>
                                </div>
                            </div>
                        </div>

                        <!-- ── Bloque CheckId: resultado ─────────────────── -->
                        <div invisible="not checkid_done"
                             class="alert alert-info mt-2" role="alert">
                            <i class="fa fa-check-circle text-success"/>
                            <b>CheckId ejecutado:</b>
                            <field name="checkid_count_ok" readonly="1"/> consultas exitosas,
                            <field name="checkid_count_error" readonly="1"/> con error.
                        </div>

                    </div>

                    <notebook>

                        <!-- ── Configuración ─────────────────────────────── -->
                        <page string="Configuración de Importación" name="config"
                              invisible="import_done">
                            <group>
                                <group string="Archivo">
                                    <field name="file_data"
                                           widget="binary"
                                           filename="file_name"
                                           string="Archivo XLS/XLSX (formato TEVA)"
                                           required="1"/>
                                    <field name="file_name" invisible="1"/>
                                </group>
                                <group string="Destino">
                                    <field name="company_id" required="1"/>
                                    <field name="header_row"/>
                                </group>
                            </group>
                            <group>
                                <group string="Comportamiento ante duplicados">
                                    <field name="skip_duplicates"/>
                                    <field name="update_existing"
                                           invisible="not skip_duplicates"/>
                                </group>
                                <group string="Opciones adicionales">
                                    <field name="validate_rfc_format"/>
                                    <field name="link_multicompany"/>
                                </group>
                            </group>
                            <group string="Configuración de Salario Informativo">
                                <field name="salary_imss_pct"
                                       help="Porcentaje del sueldo mensual que se considera parte IMSS. El resto se guarda como exento."/>
                            </group>
                            <div class="alert alert-info mt-2" role="alert">
                                <i class="fa fa-file-excel-o"/> <b>Formato esperado:</b>
                                Plantilla TEVA de 52 columnas. Fila 1 = encabezados, datos desde fila 2.
                            </div>
                        </page>

                        <!-- ── Resultados ────────────────────────────────── -->
                        <page string="Resultados" name="results"
                              invisible="not import_done">
                            <field name="result_line_ids" readonly="1">
                                <list decoration-success="status == 'created'"
                                      decoration-info="status == 'updated'"
                                      decoration-warning="status == 'skipped'"
                                      decoration-danger="status == 'error'">
                                    <field name="row_number" string="Fila"/>
                                    <field name="employee_name" string="Nombre"/>
                                    <field name="rfc" string="RFC"/>
                                    <field name="rfc_format_ok" widget="boolean" string="RFC ✓"/>
                                    <field name="status"
                                           widget="badge"
                                           decoration-success="status == 'created'"
                                           decoration-info="status == 'updated'"
                                           decoration-warning="status == 'skipped'"
                                           decoration-danger="status == 'error'"
                                           string="Resultado"/>
                                    <field name="message" string="Mensaje"/>
                                    <field name="employee_id" string="Empleado" optional="show"/>
                                </list>
                            </field>
                        </page>

                    </notebook>

                    <!-- Campos invisibles necesarios para lógica de vista -->
                    <field name="checkid_available" invisible="1"/>
                    <field name="checkid_pending" invisible="1"/>
                    <field name="checkid_done" invisible="1"/>

                </sheet>

                <footer>
                    <button name="action_import"
                            string="Importar Empleados"
                            type="object"
                            class="btn-primary"
                            invisible="import_done"
                            confirm="¿Confirma la importación? Se crearán/actualizarán empleados en la empresa seleccionada."/>
                    <button name="action_open_employees"
                            string="Ver Empleados Importados"
                            type="object"
                            class="btn-secondary"
                            invisible="not import_done"/>
                    <button name="action_close"
                            string="Cerrar"
                            type="object"
                            class="btn-secondary"/>
                </footer>

            </form>
        </field>
    </record>

    <record id="action_employee_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar Empleados (TEVA)</field>
        <field name="res_model">mx.employee.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_employee_import_wizard_form"/>
    </record>

</odoo>
