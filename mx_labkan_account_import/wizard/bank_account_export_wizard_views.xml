<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ═══════════════════════════════════════════════════
             DESCARGA MASIVA TXT CUENTAS BANCARIAS
        ═══════════════════════════════════════════════════ -->
        <record id="view_mx_bank_account_export_wizard_form" model="ir.ui.view">
            <field name="name">mx.bank.account.export.wizard.form</field>
            <field name="model">mx.bank.account.export.wizard</field>
            <field name="arch" type="xml">
                <form string="Descarga Masiva TXT - Cuentas Bancarias">

                    <!-- Resultado generado -->
                    <div class="alert alert-success mb-0" role="alert"
                         invisible="state != 'done'">
                        <strong>✅ Archivo generado correctamente</strong><br/>
                        <span>Registros exportados: </span>
                        <field name="records_exported" readonly="1" nolabel="1" class="fw-bold"/>
                        <br/>
                        <small>Haz clic en "Descargar TXT" para guardar el archivo.</small>
                    </div>

                    <!-- Formulario -->
                    <group invisible="state != 'draft'">
                        <group string="Formato y Compañía">
                            <field name="bank_type" required="1" widget="radio"/>
                            <field name="company_id" options="{'no_create': True}"/>
                            <field name="uso_cuenta" invisible="bank_type != 'inbursa'"/>
                        </group>
                        <group string="Filtros (opcionales)">
                            <field name="partner_ids" widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Todos los contactos"/>
                            <field name="bank_id" options="{'no_create': True}"
                                   placeholder="Todos los bancos"/>
                            <field name="only_active" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <!-- Info formato -->
                    <div class="alert alert-info" role="alert" invisible="state != 'draft'">
                        <strong>Formato Inbursa:</strong>
                        <code>NoCuenta|UsoDestino</code><br/>
                        <strong>Formato Otros Bancos:</strong>
                        <code>Celular/Tarjeta/CLABE|NombreBeneficiario|RFC|Banco</code><br/>
                        <small>El archivo se genera en codificación Latin-1 compatible con los portales bancarios.</small>
                    </div>

                    <!-- Descarga -->
                    <group invisible="state != 'done'">
                        <field name="result_file" widget="binary"
                               filename="result_filename"
                               string="Archivo TXT"
                               readonly="1"/>
                        <field name="result_filename" invisible="1"/>
                    </group>

                    <footer>
                        <div invisible="state != 'draft'">
                            <button name="action_generate_txt" type="object"
                                    string="⬇️ Generar TXT"
                                    class="btn-primary"
                                    data-hotkey="q"/>
                            <button string="Cancelar" class="btn-secondary" special="cancel"/>
                        </div>
                        <div invisible="state == 'draft'">
                            <button name="action_download" type="object"
                                    string="💾 Descargar TXT"
                                    class="btn-primary"/>
                            <button string="Cerrar" class="btn-secondary" special="cancel"/>
                        </div>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_mx_bank_account_export_wizard" model="ir.actions.act_window">
            <field name="name">Descarga Masiva TXT Cuentas Bancarias</field>
            <field name="res_model">mx.bank.account.export.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
