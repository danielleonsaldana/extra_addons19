<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_recibo_nomina" model="report.paperformat">
        <field name="name">Recibo de Nómina MX</field>
        <field name="default" eval="False"/>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">6</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_recibo_nomina" model="ir.actions.report">
        <field name="name">Recibo de Nómina</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">mx_jandea_nomina_recibo.report_recibo_nomina</field>
        <field name="report_file">mx_jandea_nomina_recibo.report_recibo_nomina</field>
        <field name="paperformat_id" ref="paperformat_recibo_nomina"/>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Recibo - %s' % (object.employee_id.name or '')</field>
    </record>

</odoo>
