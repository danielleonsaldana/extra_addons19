<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="checkid_wizard_view_form" model="ir.ui.view">
        <field name="name">mx.checkid.wizard.view.form</field>
        <field name="model">mx.checkid.wizard</field>
        <field name="arch" type="xml">
            <form string="Consultar CheckId">
                <sheet>
                    <group>
                        <field name="employee_id" readonly="1"/>
                        <field name="termino_busqueda"
                               placeholder="Ej: MALD850101HDF001 ó MALD850101XY3"/>
                        <field name="tipo_detectado" readonly="1" force_save="1"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>Nota:</strong> Ingrese el RFC (12-13 caracteres para persona
                        moral/física) o la CURP (18 caracteres) del empleado.
                        La consulta consumirá una solicitud de su cuenta CheckId.
                    </div>
                </sheet>
                <footer>
                    <button type="object"
                            name="action_consultar"
                            string="Consultar"
                            class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
