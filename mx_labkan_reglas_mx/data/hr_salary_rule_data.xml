    <!-- Impuesto Local: la tasa varía por estado (CDMX 3%, EdoMex 3%, etc.).
         AJUSTAR el valor 0.03 según el estado del centro de trabajo antes
         de usar en producción, o convertir a campo de configuración. -->
    <record id="rule_impuesto_local" model="hr.salary.rule">
        <field name="name">Impuesto Local (ISN)</field>
        <field name="code">IMPUESTO_LOCAL</field>
        <field name="category_id" ref="hr_payroll.DED"/>
        <field name="sequence">184</field>
        <field name="condition_select">none</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">
TASA_ISN = 0.03  # AJUSTAR por estado
result = -categories['GROSS'] * TASA_ISN
        </field>
        <field name="struct_id" ref="l10n_mx_hr_payroll.l10n_mx_regular_pay"/>
    </record>
</odoo>
