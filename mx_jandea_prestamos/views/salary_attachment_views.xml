<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Acción "Préstamos": abre los ajustes salariales (hr.salary.attachment)
        filtrados al concepto Préstamo y, al crear uno nuevo, asigna ese
        concepto por default.
    -->
    <record id="action_mx_jandea_prestamos" model="ir.actions.act_window">
        <field name="name">Préstamos</field>
        <field name="res_model">hr.salary.attachment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('other_input_type_id', '=', %(input_type_prestamo)d)]</field>
        <field name="context">{'default_other_input_type_id': %(input_type_prestamo)d}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registra un préstamo a un empleado</p>
            <p>
                El concepto <b>Préstamo</b> se asigna automáticamente. Usa la
                duración <b>Limitado</b>, captura el monto total del préstamo y
                el monto a descontar por recibo. Odoo descontará en cada nómina
                hasta saldarlo y cerrará el registro automáticamente.
            </p>
        </field>
    </record>

    <!--
        El menú "Préstamos" NO se define aquí. Se crea en el post_init_hook
        (ver hooks.py) buscando dinámicamente el menú nativo de Ajustes
        Salariales, para no depender de un xmlid de menú que cambia entre
        versiones/ediciones de Odoo.
    -->

</odoo>
